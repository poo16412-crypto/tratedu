                <span className="text-[10px] sm:text-xs text-gray-600 mt-2 text-center truncate w-full px-1">
                  {item.name.replace('เมืองตราด', 'เมือง').replace('แหลมงอบ', 'แหลมฯ')}
                </span>
              </div>
            );
          })}
        </div>
      )}
    </div>
  );
};

