                 </div>
                 <div className="w-full bg-gray-200 rounded-full h-1 mt-3">
                    <div className="bg-[#D4AF37] h-1 rounded-full" style={{ width: `${(type.value / liveData.totalStudents) * 100}%` }}></div>
                 </div>
              </div>
